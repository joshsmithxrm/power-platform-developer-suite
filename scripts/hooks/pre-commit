#!/usr/bin/env bash
# pre-commit hook: run build/test gates on staged files
# Install: git config core.hooksPath scripts/hooks

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

# Run pre-commit.d/*.sh — extensible drop-in scripts.
# Each script is sourced (sourced so they share REPO_ROOT and abort on error).
if [ -d "$REPO_ROOT/scripts/hooks/pre-commit.d" ]; then
    for script in "$REPO_ROOT/scripts/hooks/pre-commit.d"/*.sh; do
        [ -e "$script" ] || continue
        echo "[pre-commit] running $(basename "$script")..."
        if ! bash "$script"; then
            echo "[pre-commit] BLOCKED: $(basename "$script") failed." >&2
            exit 1
        fi
    done
fi

# ── .NET Gate ──────────────────────────────────────────────────
STAGED_CS=$(git diff --cached --name-only --diff-filter=ACMR -- ':(glob)**/*.cs' ':(glob)**/*.csproj')

if [ -n "$STAGED_CS" ]; then
    echo "[pre-commit] C# files staged — running .NET build..."

    if ! dotnet build "$REPO_ROOT/PPDS.sln" -v q; then
        echo ""
        echo "[pre-commit] BLOCKED: .NET build failed. Fix errors before committing."
        exit 1
    fi

    echo "[pre-commit] .NET build passed."
    echo "[pre-commit] Running .NET unit tests..."

    if ! dotnet test "$REPO_ROOT/PPDS.sln" \
        --filter "Category!=Integration&Category!=SecureStorage&Category!=SlowIntegration&Category!=DestructiveE2E" \
        -v q --no-build; then
        echo ""
        echo "[pre-commit] BLOCKED: .NET tests failed. Fix failures before committing."
        exit 1
    fi

    echo "[pre-commit] .NET tests passed."
fi

# ── Extension Contribution Lint ────────────────────────────────
if git diff --cached --name-only --diff-filter=ACMR | grep -q "^src/PPDS\.Extension/package\.json$"; then
    echo "[pre-commit] Extension package.json staged — linting contributions..."
    if ! node "$REPO_ROOT/scripts/docs-gen/lint-extension-contributions.js" --package-json "$REPO_ROOT/src/PPDS.Extension/package.json"; then
        echo ""
        echo "[pre-commit] BLOCKED: extension contribution lint failed. Fix errors before committing."
        exit 1
    fi
    echo "[pre-commit] Extension contribution lint passed."
fi

# ── TypeScript Gate ────────────────────────────────────────────
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR -- ':(glob)src/PPDS.Extension/**/*.ts' ':(glob)src/PPDS.Extension/**/*.tsx' ':(glob)src/PPDS.Extension/**/*.js')

if [ -z "$STAGED_TS" ]; then
    exit 0
fi

echo "[pre-commit] Extension TS files staged — running typecheck..."

EXT_DIR="$REPO_ROOT/src/PPDS.Extension"

if [ ! -f "$EXT_DIR/package.json" ]; then
    echo "[pre-commit] WARNING: src/PPDS.Extension/package.json not found, skipping typecheck"
    exit 0
fi

if [ ! -d "$EXT_DIR/node_modules" ]; then
    echo "[pre-commit] WARNING: node_modules missing, skipping typecheck (run npm install)"
    exit 0
fi

if ! npm run typecheck:all --prefix "$EXT_DIR"; then
    echo ""
    echo "[pre-commit] BLOCKED: typecheck failed. Fix errors before committing."
    exit 1
fi

echo "[pre-commit] typecheck passed."

echo "[pre-commit] Running lint..."
if ! (cd "$EXT_DIR" && npx eslint src --quiet); then
    echo ""
    echo "[pre-commit] BLOCKED: lint errors found. Fix errors before committing."
    exit 1
fi

echo "[pre-commit] lint passed."

echo "[pre-commit] Running Extension unit tests..."
if ! npm test --prefix "$EXT_DIR"; then
    echo ""
    echo "[pre-commit] BLOCKED: Extension tests failed. Fix failures before committing."
    exit 1
fi
echo "[pre-commit] Extension tests passed."
