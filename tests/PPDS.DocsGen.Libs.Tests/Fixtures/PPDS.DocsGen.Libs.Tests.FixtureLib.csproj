<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>PPDS.DocsGen.Libs.Tests.FixtureLib</RootNamespace>
    <AssemblyName>PPDS.DocsGen.Libs.Tests.FixtureLib</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- CS1591: missing XML comment — we test behavior of the generator when some types lack summaries, so silence the warning here. -->
    <!-- CS1574: cref could not be resolved — the fallback fixture below intentionally
         uses an unresolvable cref to exercise the inheritdoc fallback path. -->
    <NoWarn>$(NoWarn);CS1591;CS1574</NoWarn>
  </PropertyGroup>

</Project>
