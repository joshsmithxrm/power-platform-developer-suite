{
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}/extension"
  },
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "path": "extension",
      "problemMatcher": "$tsc",
      "label": "npm: compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "extension",
      "problemMatcher": "$tsc-watch",
      "label": "npm: watch",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "type": "npm",
      "script": "lint",
      "path": "extension",
      "problemMatcher": "$eslint-stylish",
      "label": "npm: lint",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "package",
      "path": "extension",
      "label": "npm: package",
      "detail": "Create .vsix package (pre-release)",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "rm -rf dist",
      "windows": {
        "command": "if exist dist rmdir /s /q dist"
      },
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Rebuild",
      "dependsOn": ["Clean", "npm: compile"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "npm ci",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "local",
      "path": "extension",
      "label": "npm: local",
      "detail": "Build and install dev extension to VS Code",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "test-release",
      "path": "extension",
      "label": "npm: test-release",
      "detail": "Full package + .vsix + install (simulates release)",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "marketplace",
      "path": "extension",
      "label": "npm: marketplace",
      "detail": "Revert to marketplace version",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "test",
      "path": "extension",
      "label": "npm: test",
      "detail": "Run vitest unit tests",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "type": "npm",
      "script": "test:e2e",
      "path": "extension",
      "label": "npm: test:e2e",
      "detail": "Run Playwright e2e tests",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
