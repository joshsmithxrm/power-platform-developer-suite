{
  "name": "power-platform-developer-suite",
  "displayName": "Power Platform Developer Suite",
  "description": "Comprehensive development tools for Microsoft Dataverse and Power Platform",
  "version": "0.4.0-alpha.1",
  "publisher": "JoshSmithXRM",
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Azure",
    "Other"
  ],
  "keywords": [
    "Power Platform",
    "Dataverse",
    "Dynamics 365",
    "CRM",
    "Microsoft"
  ],
  "activationEvents": [
    "onView:ppds.profiles",
    "onNotebook:ppdsnb"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ppds",
          "title": "Power Platform Developer Suite",
          "icon": "images/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "ppds": [
        {
          "id": "ppds.profiles",
          "name": "Profiles"
        },
        {
          "id": "ppds.tools",
          "name": "Tools"
        },
        {
          "id": "ppds.solutions",
          "name": "Solutions"
        }
      ]
    },
    "commands": [
      {
        "command": "ppds.listProfiles",
        "title": "PPDS: List Profiles"
      },
      {
        "command": "ppds.refreshProfiles",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ppds.selectProfile",
        "title": "PPDS: Select Profile"
      },
      {
        "command": "ppds.profileDetails",
        "title": "PPDS: Profile Details"
      },
      {
        "command": "ppds.createProfile",
        "title": "PPDS: Create Profile",
        "icon": "$(add)"
      },
      {
        "command": "ppds.deleteProfile",
        "title": "PPDS: Delete Profile",
        "icon": "$(trash)"
      },
      {
        "command": "ppds.renameProfile",
        "title": "PPDS: Rename Profile",
        "icon": "$(edit)"
      },
      {
        "command": "ppds.selectEnvironment",
        "title": "PPDS: Select Environment"
      },
      {
        "command": "ppds.environmentDetails",
        "title": "PPDS: Environment Details"
      },
      {
        "command": "ppds.refreshEnvironments",
        "title": "PPDS: Refresh Environments",
        "icon": "$(refresh)"
      },
      {
        "command": "ppds.configureEnvironment",
        "title": "PPDS: Configure Environment",
        "icon": "$(gear)"
      },
      {
        "command": "ppds.newNotebook",
        "title": "PPDS: New Notebook",
        "icon": "$(notebook)"
      },
      {
        "command": "ppds.toggleNotebookCellLanguage",
        "title": "PPDS: Toggle SQL/FetchXML",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "ppds.openCellInDataExplorer",
        "title": "PPDS: Open in Data Explorer",
        "icon": "$(table)"
      },
      {
        "command": "ppds.exportCellResultsCsv",
        "title": "PPDS: Export Cell Results to CSV",
        "icon": "$(file)"
      },
      {
        "command": "ppds.exportCellResultsJson",
        "title": "PPDS: Export Cell Results to JSON",
        "icon": "$(json)"
      },
      {
        "command": "ppds.selectNotebookEnvironment",
        "title": "PPDS: Select Notebook Environment",
        "icon": "$(database)"
      },
      {
        "command": "ppds.dataExplorer",
        "title": "PPDS: Data Explorer",
        "icon": "$(database)"
      },
      {
        "command": "ppds.openQueryInNotebook",
        "title": "PPDS: Open Query in Notebook",
        "icon": "$(notebook)"
      },
      {
        "command": "ppds.openNotebooks",
        "title": "PPDS: Open Notebooks",
        "icon": "$(notebook)"
      },
      {
        "command": "ppds.openSolutions",
        "title": "PPDS: Open Solutions",
        "icon": "$(package)"
      },
      {
        "command": "ppds.refreshSolutions",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ppds.toggleManagedSolutions",
        "title": "Toggle Managed Solutions",
        "icon": "$(filter)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ppds.refreshProfiles",
          "when": "view == ppds.profiles",
          "group": "navigation"
        },
        {
          "command": "ppds.createProfile",
          "when": "view == ppds.profiles",
          "group": "navigation"
        },
        {
          "command": "ppds.refreshSolutions",
          "when": "view == ppds.solutions",
          "group": "navigation"
        },
        {
          "command": "ppds.toggleManagedSolutions",
          "when": "view == ppds.solutions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ppds.selectProfile",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "ppds.profileDetails",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "profile@1"
        },
        {
          "command": "ppds.renameProfile",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "profile@2"
        },
        {
          "command": "ppds.deleteProfile",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "profile@3"
        }
      ],
      "notebook/cell/title": [
        {
          "command": "ppds.toggleNotebookCellLanguage",
          "when": "notebookType == ppdsnb",
          "group": "inline@1"
        },
        {
          "command": "ppds.openCellInDataExplorer",
          "when": "notebookType == ppdsnb && notebookCellType == code",
          "group": "inline@2"
        },
        {
          "command": "ppds.exportCellResultsCsv",
          "when": "notebookType == ppdsnb && notebookCellType == code",
          "group": "export@1"
        },
        {
          "command": "ppds.exportCellResultsJson",
          "when": "notebookType == ppdsnb && notebookCellType == code",
          "group": "export@2"
        }
      ]
    },
    "notebooks": [
      {
        "type": "ppdsnb",
        "displayName": "Power Platform Developer Suite Notebook",
        "selector": [
          {
            "filenamePattern": "*.ppdsnb"
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "fetchxml",
        "aliases": [
          "FetchXML",
          "fetchxml"
        ],
        "extensions": [
          ".fetchxml"
        ]
      }
    ],
    "configuration": {
      "title": "Power Platform Developer Suite",
      "properties": {
        "ppds.queryDefaultTop": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 5000,
          "description": "Default TOP value for SQL queries when none specified"
        },
        "ppds.autoStartDaemon": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the ppds serve daemon when the extension activates"
        },
        "ppds.showEnvironmentInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the active environment in the VS Code status bar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.109.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshsmithxrm/power-platform-developer-suite.git"
  },
  "bugs": {
    "url": "https://github.com/joshsmithxrm/power-platform-developer-suite/issues"
  },
  "homepage": "https://github.com/joshsmithxrm/power-platform-developer-suite#readme",
  "license": "MIT",
  "icon": "images/icon.png"
}
