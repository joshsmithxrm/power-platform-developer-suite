{
  "name": "power-platform-developer-suite",
  "displayName": "Power Platform Developer Suite",
  "description": "Comprehensive development tools for Microsoft Dataverse and Power Platform",
  "version": "0.4.0-alpha.1",
  "publisher": "JoshSmithXRM",
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Azure",
    "Other"
  ],
  "keywords": [
    "Power Platform",
    "Dataverse",
    "Dynamics 365",
    "CRM",
    "Microsoft"
  ],
  "activationEvents": [
    "onView:ppds.profiles"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ppds",
          "title": "Power Platform Developer Suite",
          "icon": "images/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "ppds": [
        {
          "id": "ppds.profiles",
          "name": "Profiles"
        },
        {
          "id": "ppds.tools",
          "name": "Tools"
        }
      ]
    },
    "commands": [
      {
        "command": "ppds.listProfiles",
        "title": "PPDS: List Profiles"
      },
      {
        "command": "ppds.refreshProfiles",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ppds.selectProfile",
        "title": "PPDS: Select Profile"
      },
      {
        "command": "ppds.profileDetails",
        "title": "PPDS: Profile Details"
      },
      {
        "command": "ppds.createProfile",
        "title": "PPDS: Create Profile",
        "icon": "$(add)"
      },
      {
        "command": "ppds.deleteProfile",
        "title": "PPDS: Delete Profile",
        "icon": "$(trash)"
      },
      {
        "command": "ppds.renameProfile",
        "title": "PPDS: Rename Profile",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ppds.refreshProfiles",
          "when": "view == ppds.profiles",
          "group": "navigation"
        },
        {
          "command": "ppds.createProfile",
          "when": "view == ppds.profiles",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ppds.selectProfile",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "inline"
        },
        {
          "command": "ppds.profileDetails",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "profile@1"
        },
        {
          "command": "ppds.renameProfile",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "profile@2"
        },
        {
          "command": "ppds.deleteProfile",
          "when": "view == ppds.profiles && viewItem == profile",
          "group": "profile@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshsmithxrm/power-platform-developer-suite.git"
  },
  "bugs": {
    "url": "https://github.com/joshsmithxrm/power-platform-developer-suite/issues"
  },
  "homepage": "https://github.com/joshsmithxrm/power-platform-developer-suite#readme",
  "license": "MIT",
  "icon": "images/icon.png"
}
