<?xml version="1.0" encoding="utf-8"?>
<!--
  Pin NuGet sources to nuget.org only.

  PPDS uses Central Package Management (CPM, see Directory.Packages.props).
  NuGet's NU1507 rule requires source mapping whenever more than one source is
  configured at any scope (user / machine / repo). Without this file, anyone
  whose user-level NuGet config (%appdata%\NuGet\NuGet.config on Windows,
  ~/.config/NuGet/NuGet.Config on Linux/macOS) registers a second feed — even
  one PPDS does not consume — gets a build break promoted to error.

  <clear /> drops inherited sources so the repo build is reproducible regardless
  of contributor machine state. Add a project-scoped feed here only if PPDS
  actually depends on a package from it.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
